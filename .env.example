# FrameLab Academy - Environment Variables

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/framelab"

# NextAuth
NEXTAUTH_URL="https://academy.framelab.com"
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"

# Admin Credentials (default: admin / admin123)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123"

# Student Credentials (default: student / student123)
STUDENT_USERNAME="student"
STUDENT_PASSWORD="student123"

# Meta API (optional)
META_ACCESS_TOKEN=""
META_AD_ACCOUNT_ID=""

# Email (optional)
EMAIL_SERVER=""
EMAIL_FROM=""
