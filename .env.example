# Environment Configuration - Clawport Control Center
# Copy this file to .env and fill in your values

# ============================================
# Application
# ============================================
NODE_ENV=production
PORT=3000

# ============================================
# Security
# ============================================
# Generate with: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ============================================
# Database (PostgreSQL)
# ============================================
DATABASE_URL=postgresql://clawport:clawport123@db:5432/clawport
POSTGRES_USER=clawport
POSTGRES_PASSWORD=clawport123
POSTGRES_DB=clawport

# ============================================
# Redis
# ============================================
REDIS_URL=redis://redis:6379

# ============================================
# AI/LLM Integration
# ============================================
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=gensee-397b/Gensee/Qwen3.5-397B

# ============================================
# Monitoring (Optional)
# ============================================
GRAFANA_ADMIN_PASSWORD=admin123
WATCHTOWER_NOTIFICATION_SLACK_HOOK_URL=

# ============================================
# Email (Optional)
# ============================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@clawport.com

# ============================================
# File Storage (Optional)
# ============================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1
